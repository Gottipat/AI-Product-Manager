# Copy this file to .env.docker before running docker compose.

# Shared
NODE_ENV=development

# AI Backend
AI_BACKEND_PORT=3002
DATABASE_PORT=5432
POSTGRES_USER=meeting_ai
POSTGRES_PASSWORD=password
POSTGRES_DB=meeting_ai
DATABASE_URL=postgresql://meeting_ai:password@postgres:5432/meeting_ai
OPENAI_API_KEY=sk-your-openai-key
# Optional for local Docker only. Safe dev defaults already exist in docker-compose.yml.
JWT_SECRET=local-dev-jwt-secret-change-me-if-you-want
COOKIE_SECRET=local-dev-cookie-secret-change-me-if-you-want

# Web
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3002/api/v1

# Bot Runner (optional profile: bot)
BOT_DISPLAY_NAME=Meeting AI Bot
HEADLESS=true
AI_BACKEND_INTERNAL_URL=http://ai-backend:3002
MEET_LINK=
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
