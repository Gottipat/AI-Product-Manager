{
    "name": "@meeting-ai/bot-runner",
    "version": "0.0.1",
    "private": true,
    "description": "Playwright-based bot for joining Google Meet and capturing captions",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "predev": "pkill -f 'tsx.*bot-runner' 2>/dev/null; pkill -f 'Chrome for Testing' 2>/dev/null; exit 0",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rm -rf dist; pkill -f 'Chrome for Testing' 2>/dev/null; exit 0"
    },
    "dependencies": {
        "@meeting-ai/shared": "workspace:*",
        "playwright": "^1.41.0",
        "ws": "^8.16.0",
        "dotenv": "^16.4.0",
        "pino": "^8.18.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/ws": "^8.5.10",
        "@types/uuid": "^9.0.0",
        "tsx": "^4.7.0",
        "vitest": "^1.2.0"
    }
}
