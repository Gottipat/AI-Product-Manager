{
  "manifest_version": 3,
  "name": "Meeting AI — Transcript Capture",
  "version": "1.0.0",
  "description": "Capture Google Meet transcripts and stream them to your Meeting AI backend for AI-powered analysis, MoM generation, and action item extraction.",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": ["https://meet.google.com/*", "http://localhost:*/*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content/caption-observer.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Meeting AI Transcript Capture"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
