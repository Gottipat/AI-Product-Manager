{
  "name": "@meeting-ai/ai-backend",
  "version": "0.0.1",
  "private": true,
  "description": "AI extraction, MoM generation, and RAG system for meeting analysis",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/websocket": "^8.3.0",
    "@meeting-ai/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^4.25.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.104.0",
    "pino": "^8.18.0",
    "postgres": "^3.4.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  }
}