{
    "name": "@meeting-ai/ai-backend",
    "version": "0.0.1",
    "private": true,
    "description": "AI extraction, MoM generation, and RAG system for meeting analysis",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
