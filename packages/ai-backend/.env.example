# AI Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE
# ============================================================================

# Local Development (Docker/local PostgreSQL)
DATABASE_URL=postgresql://meeting_ai:password@localhost:5432/meeting_ai

# Production (Supabase) - uncomment and configure for production
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# SUPABASE_URL=https://[project].supabase.co
# SUPABASE_ANON_KEY=eyJ...

# ============================================================================
# SERVER
# ============================================================================

PORT=3000
NODE_ENV=development

# ============================================================================
# OPENAI API
# ============================================================================

# Required for AI features (MoM generation, action item extraction, search)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom model configuration
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# LOGGING & MONITORING (optional)
# ============================================================================

# LOG_LEVEL=info
# SENTRY_DSN=https://...
