{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meeting-ai.local/schemas/longitudinal-scenario.schema.json",
  "title": "Longitudinal Benchmark Scenario",
  "type": "object",
  "required": ["schemaVersion", "scenarioId", "displayName", "project", "meetings"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "scenarioId": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "isRecurring": {
          "type": "boolean"
        }
      }
    },
    "defaultAnalysisMode": {
      "type": "string",
      "enum": ["general", "product_manager"]
    },
    "defaultContextNote": {
      "type": "string"
    },
    "meetings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sequenceNumber", "slug", "title", "transcriptPath"],
        "properties": {
          "sequenceNumber": {
            "type": "integer",
            "minimum": 1
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "transcriptPath": {
            "type": "string"
          },
          "analysisMode": {
            "type": "string",
            "enum": ["general", "product_manager"]
          },
          "contextNote": {
            "type": "string"
          },
          "expectations": {
            "type": "object",
            "properties": {
              "mustIncludeItemTitles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "mustNotIncludeItemTitles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "mustIncludeSummaryPhrases": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "finalProjectExpectations": {
      "type": "object",
      "properties": {
        "mustHaveItemStatuses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["titleLike", "status"],
            "properties": {
              "titleLike": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            }
          }
        },
        "mustNotHaveOpenTitles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
